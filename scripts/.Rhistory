value_box("MDR — latest year",          textOutput("mdr_latest"),   theme="info"),
value_box("WGS isolates (Bangladesh)",  textOutput("n_wgs"),        theme="secondary")
),
card(card_header("24-Year Phenotypic AMR Trends — Bangladesh (Tanmoy et al. 2024)"),
plotlyOutput("main_trend", height="420px")),
layout_columns(col_widths=c(6,6),
card(card_header("Data — Phenotypic Layer"),
markdown("**Tanmoy AM et al. (2024)** PLOS NTDs 18(10): e0012558
[doi.org/10.1371/journal.pntd.0012558](https://doi.org/10.1371/journal.pntd.0012558)
12,435 culture-confirmed isolates · Dhaka · 1999–2022 · CLSI breakpoints")),
card(card_header("Data — Genomic Layer"),
markdown("**TyphiNET Database** (https://www.typhi.net/)
1,664 WGS isolates · Bangladesh · Dashboard-quality filter applied
Genotype · AMR determinants · gyrA/parC/acrB mutations"))
)
),
# Tab 2: Phenotypic Trends ────────────────────────────────
nav_panel("Phenotypic Trends",
layout_sidebar(
sidebar=sidebar(
checkboxGroupInput("sel_ab","Select antibiotics:",
choices=ab_choices, selected=names(ab_choices)[1:4]),
sliderInput("yr","Year range:",
min=min(bangladesh$year), max=max(bangladesh$year),
value=c(min(bangladesh$year),max(bangladesh$year)), sep="", step=1)
),
card(plotlyOutput("custom_trend", height="430px")),
layout_columns(col_widths=c(6,6),
card(card_header("Summary"), tableOutput("trend_tbl")),
card(card_header("First vs Latest Year"), tableOutput("fl_tbl"))
)
)
),
# Tab 3: Consumption vs AMR ────────────────────────────────
nav_panel("Consumption vs AMR",
layout_sidebar(
sidebar=sidebar(
selectInput("pair","Antibiotic pair:",
choices=c("Cotrimoxazole vs MDR"="cot",
"Ciprofloxacin vs Cipro NS"="cip",
"Azithromycin vs Azi R"="azi"), selected="cot"),
helpText("Consumption-drives-resistance hypothesis · Tanmoy et al. 2024")
),
card(plotlyOutput("scatter", height="460px"))
)
),
# Tab 4: Genomic Layer ────────────────────────────────────
nav_panel("Genomic Analysis",
layout_columns(col_widths=c(12),
card(card_header("⚠️ Two layers of the same story"),
markdown("The phenotypic data (Tanmoy) shows **what** resistance rates look like.
The genomic data (TyphiNET) shows **why** — the specific mutations encoding that resistance.
Together they make a mechanistic argument, not just an observational one."))
),
layout_columns(col_widths=c(6,6),
card(card_header("CipNS vs CipR Over Time"),
plotlyOutput("cip_escalation", height="380px")),
card(card_header("gyrA Mutation Landscape"),
plotlyOutput("gyra_plot", height="380px"))
),
card(card_header("Genotype Distribution in Bangladesh (TyphiNET)"),
plotlyOutput("genotype_plot", height="340px"))
),
# Tab 5: South Asia Comparison ────────────────────────────
nav_panel("South Asia",
layout_sidebar(
sidebar=sidebar(
radioButtons("sa_metric","Show:",
choices=c("Cipro NS"="cip_ns","Cipro R"="cip_r",
"Ceftriaxone R"="cef_r","XDR"="is_xdr","MDR"="is_mdr"),
selected="cip_ns"),
helpText("Source: TyphiNET Database"),
hr(),
markdown("**Key comparison:**
Bangladesh: **0% XDR**
Pakistan: **35.4% XDR**
Bangladesh is at the exact inflection point Pakistan occupied before its 2016–2019 XDR outbreak.")
),
card(card_header("South Asia: AMR metric by country and year"),
plotlyOutput("sa_trend", height="440px"))
)
),
# Tab 6: Raw Data ─────────────────────────────────────────
nav_panel("Raw Data",
navset_tab(
nav_panel("Phenotypic (Tanmoy)",
card(DTOutput("raw_pheno"))),
nav_panel("Genomic Bangladesh (TyphiNET)",
card(DTOutput("raw_genomic")))
)
),
# Tab 7: About ────────────────────────────────────────────
nav_panel("About",
card(markdown("
## About This Dashboard
### Two-layer AMR analysis — Bangladesh Salmonella. typhi
**Phenotypic layer:** Tanmoy AM et al. (2024) PLOS NTDs 18(10): e0012558 ·
12,435 culture-confirmed isolates · 1999–2022
**Genomic layer:** TyphiNET Database (typhinet.org) ·
1,664 WGS isolates · Bangladesh · Dashboard-quality filter
**Biological question:** Does declining MDR in Bangladesh represent genuine clinical
progress, or does it mask rising resistance to ciprofloxacin, ceftriaxone,
and azithromycin?
**Tools:** R · tidyverse · Shiny · bslib · plotly · DT · Quarto · renv
**Repo:** github.com/YOUR_USERNAME/styphi-amr-bangladesh
"))
)
)
# ── Server ────────────────────────────────────────────────────
server <- function(input, output, session) {
# Value boxes
output$n_total     <- renderText(format(sum(bangladesh$n_total,na.rm=T),big.mark=","))
output$n_wgs       <- renderText(format(nrow(bd_genomic), big.mark=","))
latest <- bangladesh %>% filter(year==max(year))
output$cipro_latest <- renderText(paste0(latest$pct_cip_ns,"%"))
output$mdr_latest   <- renderText(paste0(latest$pct_mdr,"%"))
# Main overview trend
output$main_trend <- renderPlotly({
cols <- intersect(c("pct_mdr","pct_cip_ns","pct_cef","pct_azi"), names(bangladesh))
d <- bangladesh %>%
select(year, all_of(cols)) %>%
pivot_longer(-year, names_to="m", values_to="pct") %>%
filter(!is.na(pct)) %>%
mutate(label=recode(m, pct_mdr="MDR", pct_cip_ns="Cipro NS",
pct_cef="Ceftriaxone", pct_azi="Azithromycin"))
plot_ly(d,x=~year,y=~pct,color=~label,type="scatter",mode="lines+markers",
colors=c("#2c7bb6","#d7191c","#f4a442","#7b2d8b")) %>%
layout(xaxis=list(title="Year"),
yaxis=list(title="% of isolates",range=c(0,105)),
hovermode="x unified", legend=list(orientation="h",y=-0.15))
})
# Custom phenotypic trend
output$custom_trend <- renderPlotly({
req(length(input$sel_ab)>0)
d <- bangladesh %>%
filter(between(year,input$yr[1],input$yr[2])) %>%
select(year,all_of(input$sel_ab)) %>%
pivot_longer(-year,names_to="m",values_to="pct") %>% filter(!is.na(pct))
plot_ly(d,x=~year,y=~pct,color=~m,type="scatter",mode="lines+markers") %>%
layout(hovermode="x unified", yaxis=list(title="% of isolates"))
})
output$trend_tbl <- renderTable({
req(length(input$sel_ab)>0)
bangladesh %>% select(year,all_of(input$sel_ab)) %>%
pivot_longer(-year,names_to="ab",values_to="pct") %>%
group_by(ab) %>%
summarise(Mean=round(mean(pct,na.rm=T),1),
Min=round(min(pct,na.rm=T),1),
Max=round(max(pct,na.rm=T),1),.groups="drop")
})
output$fl_tbl <- renderTable({
req(length(input$sel_ab)>0)
bangladesh %>% filter(year %in% c(min(year),max(year))) %>%
select(Year=year,all_of(input$sel_ab))
})
# Consumption scatter
output$scatter <- renderPlotly({
ddd_map <- list(
cot=list(x="ddd_cot",y="pct_mdr",   xl="Cotrimoxazole DDD",yl="% MDR",   col="#2c7bb6"),
cip=list(x="ddd_cip",y="pct_cip_ns",xl="Ciprofloxacin DDD",yl="% CipNS", col="#d7191c"),
azi=list(x="ddd_azi",y="pct_azi",   xl="Azithromycin DDD", yl="% Azi R", col="#7b2d8b")
)
sel <- ddd_map[[input$pair]]
if (!all(c(sel$x,sel$y) %in% names(bangladesh)))
return(plotly_empty() %>% layout(title="DDD columns not found — check 01_data_prep.R"))
d <- bangladesh %>% select(year,x=!!sym(sel$x),y=!!sym(sel$y)) %>% filter(!is.na(x),!is.na(y))
r <- round(cor(d$x,d$y,use="complete.obs"),2)
plot_ly(d,x=~x,y=~y,text=~paste("Year:",year),type="scatter",mode="markers",
marker=list(color=sel$col,size=9)) %>%
add_lines(x=~x,y=~fitted(lm(y~x,d)),line=list(color=sel$col,dash="dash"),
name=paste0("r = ",r)) %>%
layout(xaxis=list(title=sel$xl),yaxis=list(title=sel$yl),
legend=list(orientation="h"))
})
# CipNS vs CipR escalation
output$cip_escalation <- renderPlotly({
d <- bd_genomic %>%
filter(!is.na(year)) %>%
group_by(year) %>%
summarise(n=n(), cipNS=mean(cip_ns,na.rm=T)*100,
cipR=mean(cip_r,na.rm=T)*100, .groups="drop") %>%
filter(n>=5) %>%
pivot_longer(c(cipNS,cipR),names_to="level",values_to="pct") %>%
mutate(level=recode(level,"cipNS"="CipNS (any)","cipR"="CipR (full)"))
plot_ly(d,x=~year,y=~pct,color=~level,type="scatter",mode="lines+markers",
colors=c("#f4a442","#d7191c")) %>%
layout(xaxis=list(title="Year"),
yaxis=list(title="% of WGS isolates",range=c(0,105)),
hovermode="x unified", legend=list(orientation="h",y=-0.2))
})
# gyrA mutation bar chart
output$gyra_plot <- renderPlotly({
gyr_cols <- c("gyrA_S83F","gyrA_S83Y","gyrA_D87N","parC_E84K","acrB_R717Q")
gyr_cols <- intersect(gyr_cols, names(bd_genomic))
d <- bd_genomic %>%
select(all_of(gyr_cols)) %>%
summarise(across(everything(), ~round(mean(as.numeric(.),na.rm=T)*100,1))) %>%
pivot_longer(everything(),names_to="mutation",values_to="pct") %>%
arrange(pct)
plot_ly(d,x=~pct,y=~mutation,type="bar",orientation="h",
marker=list(color=c("#abd9e9","#abd9e9","#f4a442","#f4a442","#d7191c"))) %>%
layout(xaxis=list(title="% of Bangladesh WGS isolates",range=c(0,100)),
yaxis=list(title=NULL))
})
# Genotype distribution
output$genotype_plot <- renderPlotly({
d <- bd_genomic %>%
count(genotype) %>%
arrange(desc(n)) %>%
head(12) %>%
mutate(genotype=fct_reorder(genotype,n))
plot_ly(d,x=~n,y=~genotype,type="bar",orientation="h",
marker=list(color="#2c7bb6")) %>%
layout(xaxis=list(title="Number of WGS isolates"),yaxis=list(title=NULL))
})
# South Asia trend
output$sa_trend <- renderPlotly({
col <- input$sa_metric
if (!col %in% names(sa_genomic))
return(plotly_empty() %>% layout(title=paste("Column",col,"not found")))
d <- sa_genomic %>%
filter(!is.na(year)) %>%
group_by(country,year) %>%
summarise(pct=mean(as.numeric(!!sym(col)),na.rm=T)*100,
n=n(),.groups="drop") %>%
filter(n>=5)
plot_ly(d,x=~year,y=~pct,color=~country,type="scatter",mode="lines+markers",
colors=unname(country_pal[names(country_pal) %in% unique(d$country)])) %>%
layout(xaxis=list(title="Year"),
yaxis=list(title=paste0("% ",col),range=c(0,105)),
hovermode="x unified", legend=list(orientation="h",y=-0.15))
})
# Raw data tables
output$raw_pheno   <- renderDT(datatable(bangladesh, filter="top",
options=list(pageLength=15,scrollX=TRUE),rownames=FALSE))
output$raw_genomic <- renderDT(datatable(
bd_genomic %>% select(year, genotype, cip_cat, cip_ns, cip_r, cef_r,
is_mdr, is_xdr, gyrA_S83F, gyrA_S83Y, acrB_R717Q),
filter="top", options=list(pageLength=15,scrollX=TRUE), rownames=FALSE))
}
shinyApp(ui, server)
# shiny/app.R
# ============================================================
# Shiny Dashboard: Salmonella Typhi  AMR Bangladesh
# Two data layers:
#   Phenotypic — Tanmoy et al. 2024 (12,435 isolates)
#   Genomic    — TyphiNET database  (1,664 WGS isolates)
# ============================================================
library(shiny); library(bslib); library(tidyverse)
library(plotly); library(DT); library(here)
# ── Load data ─────────────────────────────────────────────────
bangladesh  <- readRDS(here("data","processed","bangladesh_amr.rds"))
bd_genomic  <- readRDS(here("data","processed","bd_genomic.rds"))
sa_genomic  <- readRDS(here("data","processed","sa_genomic.rds"))
ab_choices <- c(
"MDR"="pct_mdr","Ciprofloxacin NS"="pct_cip_ns",
"Ceftriaxone"="pct_cef","Azithromycin"="pct_azi",
"Ampicillin"="pct_amp","Chloramphenicol"="pct_chl","Cotrimoxazole"="pct_cot"
)
ab_choices <- ab_choices[ab_choices %in% names(bangladesh)]
country_pal <- c(Bangladesh="#d7191c",Pakistan="#2c7bb6",India="#1a9641",Nepal="#f4a442")
# ── UI ────────────────────────────────────────────────────────
ui <- page_navbar(
title = "🧬 Typhoid Fever in Bangladesh ",
theme = bs_theme(bootswatch="flatly", primary="#1a2f5a"),
bg="#1a2f5a", inverse=TRUE,
# Tab 1: Overview ─────────────────────────────────────────
nav_panel("Overview",
layout_columns(fill=FALSE, col_widths=c(3,3,3,3),
value_box("Total phenotypic isolates",  textOutput("n_total"),      theme="primary"),
value_box("Cipro NS — latest year",     textOutput("cipro_latest"), theme="danger"),
value_box("MDR — latest year",          textOutput("mdr_latest"),   theme="info"),
value_box("WGS isolates (Bangladesh)",  textOutput("n_wgs"),        theme="secondary")
),
card(card_header("24-Year Phenotypic AMR Trends — Bangladesh (Tanmoy et al. 2024)"),
plotlyOutput("main_trend", height="420px")),
layout_columns(col_widths=c(6,6),
card(card_header("Data — Phenotypic Layer"),
markdown("**Tanmoy AM et al. (2024)** PLOS NTDs 18(10): e0012558
[doi.org/10.1371/journal.pntd.0012558](https://doi.org/10.1371/journal.pntd.0012558)
12,435 culture-confirmed isolates · Dhaka · 1999–2022 · CLSI breakpoints")),
card(card_header("Data — Genomic Layer"),
markdown("**TyphiNET Database** (https://www.typhi.net/)
1,664 WGS isolates · Bangladesh · Dashboard-quality filter applied
Genotype · AMR determinants · gyrA/parC/acrB mutations"))
)
),
# Tab 2: Phenotypic Trends ────────────────────────────────
nav_panel("Phenotypic Trends",
layout_sidebar(
sidebar=sidebar(
checkboxGroupInput("sel_ab","Select antibiotics:",
choices=ab_choices, selected=names(ab_choices)[1:4]),
sliderInput("yr","Year range:",
min=min(bangladesh$year), max=max(bangladesh$year),
value=c(min(bangladesh$year),max(bangladesh$year)), sep="", step=1)
),
card(plotlyOutput("custom_trend", height="430px")),
layout_columns(col_widths=c(6,6),
card(card_header("Summary"), tableOutput("trend_tbl")),
card(card_header("First vs Latest Year"), tableOutput("fl_tbl"))
)
)
),
# Tab 3: Consumption vs AMR ────────────────────────────────
nav_panel("Consumption vs AMR",
layout_sidebar(
sidebar=sidebar(
selectInput("pair","Antibiotic pair:",
choices=c("Cotrimoxazole vs MDR"="cot",
"Ciprofloxacin vs Cipro NS"="cip",
"Azithromycin vs Azi R"="azi"), selected="cot"),
helpText("Consumption-drives-resistance hypothesis · Tanmoy et al. 2024")
),
card(plotlyOutput("scatter", height="460px"))
)
),
# Tab 4: Genomic Layer ────────────────────────────────────
nav_panel("Genomic Analysis",
layout_columns(col_widths=c(12),
card(card_header("⚠️ Two layers of the same story"),
markdown("The phenotypic data (Tanmoy) shows **what** resistance rates look like.
The genomic data (TyphiNET) shows **why** — the specific mutations encoding that resistance.
Together they make a mechanistic argument, not just an observational one."))
),
layout_columns(col_widths=c(6,6),
card(card_header("CipNS vs CipR Over Time"),
plotlyOutput("cip_escalation", height="380px")),
card(card_header("gyrA Mutation Landscape"),
plotlyOutput("gyra_plot", height="380px"))
),
card(card_header("Genotype Distribution in Bangladesh (TyphiNET)"),
plotlyOutput("genotype_plot", height="340px"))
),
# Tab 5: South Asia Comparison ────────────────────────────
nav_panel("South Asia",
layout_sidebar(
sidebar=sidebar(
radioButtons("sa_metric","Show:",
choices=c("Cipro NS"="cip_ns","Cipro R"="cip_r",
"Ceftriaxone R"="cef_r","XDR"="is_xdr","MDR"="is_mdr"),
selected="cip_ns"),
helpText("Source: TyphiNET Database"),
hr(),
markdown("**Key comparison:**
Bangladesh: **0% XDR**
Pakistan: **35.4% XDR**
Bangladesh is at the exact inflection point Pakistan occupied before its 2016–2019 XDR outbreak.")
),
card(card_header("South Asia: AMR metric by country and year"),
plotlyOutput("sa_trend", height="440px"))
)
),
# Tab 6: Raw Data ─────────────────────────────────────────
nav_panel("Raw Data",
navset_tab(
nav_panel("Phenotypic (Tanmoy)",
card(DTOutput("raw_pheno"))),
nav_panel("Genomic Bangladesh (TyphiNET)",
card(DTOutput("raw_genomic")))
)
),
# Tab 7: About ────────────────────────────────────────────
nav_panel("About",
card(markdown("
## About This Dashboard
### Two-layer AMR analysis —  Salmonella Typhi in Bangladesh
**Phenotypic layer:** Tanmoy AM et al. (2024) PLOS NTDs 18(10): e0012558 ·
12,435 culture-confirmed isolates · 1999–2022
**Genomic layer:** TyphiNET Database (typhinet.org) ·
1,664 WGS isolates · Bangladesh · Dashboard-quality filter
**Biological question:** Does declining MDR in Bangladesh represent genuine clinical
progress, or does it mask rising resistance to ciprofloxacin, ceftriaxone,
and azithromycin?
**Tools:** R · tidyverse · Shiny · bslib · plotly · DT · Quarto · renv
**Repo:** github.com/mdabrarfaiyaj/styphi-amr-bangladesh
"))
)
)
# ── Server ────────────────────────────────────────────────────
server <- function(input, output, session) {
# Value boxes
output$n_total     <- renderText(format(sum(bangladesh$n_total,na.rm=T),big.mark=","))
output$n_wgs       <- renderText(format(nrow(bd_genomic), big.mark=","))
latest <- bangladesh %>% filter(year==max(year))
output$cipro_latest <- renderText(paste0(latest$pct_cip_ns,"%"))
output$mdr_latest   <- renderText(paste0(latest$pct_mdr,"%"))
# Main overview trend
output$main_trend <- renderPlotly({
cols <- intersect(c("pct_mdr","pct_cip_ns","pct_cef","pct_azi"), names(bangladesh))
d <- bangladesh %>%
select(year, all_of(cols)) %>%
pivot_longer(-year, names_to="m", values_to="pct") %>%
filter(!is.na(pct)) %>%
mutate(label=recode(m, pct_mdr="MDR", pct_cip_ns="Cipro NS",
pct_cef="Ceftriaxone", pct_azi="Azithromycin"))
plot_ly(d,x=~year,y=~pct,color=~label,type="scatter",mode="lines+markers",
colors=c("#2c7bb6","#d7191c","#f4a442","#7b2d8b")) %>%
layout(xaxis=list(title="Year"),
yaxis=list(title="% of isolates",range=c(0,105)),
hovermode="x unified", legend=list(orientation="h",y=-0.15))
})
# Custom phenotypic trend
output$custom_trend <- renderPlotly({
req(length(input$sel_ab)>0)
d <- bangladesh %>%
filter(between(year,input$yr[1],input$yr[2])) %>%
select(year,all_of(input$sel_ab)) %>%
pivot_longer(-year,names_to="m",values_to="pct") %>% filter(!is.na(pct))
plot_ly(d,x=~year,y=~pct,color=~m,type="scatter",mode="lines+markers") %>%
layout(hovermode="x unified", yaxis=list(title="% of isolates"))
})
output$trend_tbl <- renderTable({
req(length(input$sel_ab)>0)
bangladesh %>% select(year,all_of(input$sel_ab)) %>%
pivot_longer(-year,names_to="ab",values_to="pct") %>%
group_by(ab) %>%
summarise(Mean=round(mean(pct,na.rm=T),1),
Min=round(min(pct,na.rm=T),1),
Max=round(max(pct,na.rm=T),1),.groups="drop")
})
output$fl_tbl <- renderTable({
req(length(input$sel_ab)>0)
bangladesh %>% filter(year %in% c(min(year),max(year))) %>%
select(Year=year,all_of(input$sel_ab))
})
# Consumption scatter
output$scatter <- renderPlotly({
ddd_map <- list(
cot=list(x="ddd_cot",y="pct_mdr",   xl="Cotrimoxazole DDD",yl="% MDR",   col="#2c7bb6"),
cip=list(x="ddd_cip",y="pct_cip_ns",xl="Ciprofloxacin DDD",yl="% CipNS", col="#d7191c"),
azi=list(x="ddd_azi",y="pct_azi",   xl="Azithromycin DDD", yl="% Azi R", col="#7b2d8b")
)
sel <- ddd_map[[input$pair]]
if (!all(c(sel$x,sel$y) %in% names(bangladesh)))
return(plotly_empty() %>% layout(title="DDD columns not found — check 01_data_prep.R"))
d <- bangladesh %>% select(year,x=!!sym(sel$x),y=!!sym(sel$y)) %>% filter(!is.na(x),!is.na(y))
r <- round(cor(d$x,d$y,use="complete.obs"),2)
plot_ly(d,x=~x,y=~y,text=~paste("Year:",year),type="scatter",mode="markers",
marker=list(color=sel$col,size=9)) %>%
add_lines(x=~x,y=~fitted(lm(y~x,d)),line=list(color=sel$col,dash="dash"),
name=paste0("r = ",r)) %>%
layout(xaxis=list(title=sel$xl),yaxis=list(title=sel$yl),
legend=list(orientation="h"))
})
# CipNS vs CipR escalation
output$cip_escalation <- renderPlotly({
d <- bd_genomic %>%
filter(!is.na(year)) %>%
group_by(year) %>%
summarise(n=n(), cipNS=mean(cip_ns,na.rm=T)*100,
cipR=mean(cip_r,na.rm=T)*100, .groups="drop") %>%
filter(n>=5) %>%
pivot_longer(c(cipNS,cipR),names_to="level",values_to="pct") %>%
mutate(level=recode(level,"cipNS"="CipNS (any)","cipR"="CipR (full)"))
plot_ly(d,x=~year,y=~pct,color=~level,type="scatter",mode="lines+markers",
colors=c("#f4a442","#d7191c")) %>%
layout(xaxis=list(title="Year"),
yaxis=list(title="% of WGS isolates",range=c(0,105)),
hovermode="x unified", legend=list(orientation="h",y=-0.2))
})
# gyrA mutation bar chart
output$gyra_plot <- renderPlotly({
gyr_cols <- c("gyrA_S83F","gyrA_S83Y","gyrA_D87N","parC_E84K","acrB_R717Q")
gyr_cols <- intersect(gyr_cols, names(bd_genomic))
d <- bd_genomic %>%
select(all_of(gyr_cols)) %>%
summarise(across(everything(), ~round(mean(as.numeric(.),na.rm=T)*100,1))) %>%
pivot_longer(everything(),names_to="mutation",values_to="pct") %>%
arrange(pct)
plot_ly(d,x=~pct,y=~mutation,type="bar",orientation="h",
marker=list(color=c("#abd9e9","#abd9e9","#f4a442","#f4a442","#d7191c"))) %>%
layout(xaxis=list(title="% of Bangladesh WGS isolates",range=c(0,100)),
yaxis=list(title=NULL))
})
# Genotype distribution
output$genotype_plot <- renderPlotly({
d <- bd_genomic %>%
count(genotype) %>%
arrange(desc(n)) %>%
head(12) %>%
mutate(genotype=fct_reorder(genotype,n))
plot_ly(d,x=~n,y=~genotype,type="bar",orientation="h",
marker=list(color="#2c7bb6")) %>%
layout(xaxis=list(title="Number of WGS isolates"),yaxis=list(title=NULL))
})
# South Asia trend
output$sa_trend <- renderPlotly({
col <- input$sa_metric
if (!col %in% names(sa_genomic))
return(plotly_empty() %>% layout(title=paste("Column",col,"not found")))
d <- sa_genomic %>%
filter(!is.na(year)) %>%
group_by(country,year) %>%
summarise(pct=mean(as.numeric(!!sym(col)),na.rm=T)*100,
n=n(),.groups="drop") %>%
filter(n>=5)
plot_ly(d,x=~year,y=~pct,color=~country,type="scatter",mode="lines+markers",
colors=unname(country_pal[names(country_pal) %in% unique(d$country)])) %>%
layout(xaxis=list(title="Year"),
yaxis=list(title=paste0("% ",col),range=c(0,105)),
hovermode="x unified", legend=list(orientation="h",y=-0.15))
})
# Raw data tables
output$raw_pheno   <- renderDT(datatable(bangladesh, filter="top",
options=list(pageLength=15,scrollX=TRUE),rownames=FALSE))
output$raw_genomic <- renderDT(datatable(
bd_genomic %>% select(year, genotype, cip_cat, cip_ns, cip_r, cef_r,
is_mdr, is_xdr, gyrA_S83F, gyrA_S83Y, acrB_R717Q),
filter="top", options=list(pageLength=15,scrollX=TRUE), rownames=FALSE))
}
shinyApp(ui, server)
